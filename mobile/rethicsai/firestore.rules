rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is super admin
    function isSuperAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    // Helper function to check if user has admin privileges (admin or super_admin)
    function hasAdminPrivileges() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Helper function to check if user has specific permission
    function hasPermission(permission) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) &&
             permission in get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.permissions;
    }
    
    // Users can read and write their own user documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read all user documents
      allow read: if hasAdminPrivileges();
      // Only super admins can write to other users' documents
      allow write: if isSuperAdmin();
      
      // Chat sessions - users can read/write their own chat history
      match /chatSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Per-user case-tracking mirror, written when the user reports an incident
      match /cases/{caseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if hasAdminPrivileges();
      }
    }
    
    // Public threat intelligence data (read-only for authenticated users)
    match /threat_intelligence/{threatId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Suspicious content analysis results
    match /content_analysis/{analysisId} {
      allow read, write: if request.auth != null;
    }

    // In-app notification history — per-user; legacy docs use user_id/is_read,
    // newer writers use userId/read, so ownership accepts either field.
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null &&
          (resource.data.userId == request.auth.uid ||
           resource.data.user_id == request.auth.uid);
      allow read: if hasAdminPrivileges();
    }

    // User comments - authors manage their own, admins moderate everything
    match /comments/{commentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null &&
          (resource.data.userId == request.auth.uid ||
           resource.data.user_id == request.auth.uid ||
           hasAdminPrivileges());
    }

    // Moderation audit trail - admin only
    match /moderation_logs/{logId} {
      allow read, write: if hasAdminPrivileges();
    }

    // Platform configuration managed from the admin Settings page
    match /system_settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if hasAdminPrivileges();
    }

    // Verified threat database, curated in the admin Threat Management page
    match /verified_threats/{threatId} {
      allow read: if request.auth != null;
      allow write: if hasAdminPrivileges();
    }

    // Incident activity timeline - append-only log written on status changes
    match /incident_activities/{activityId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if hasAdminPrivileges();
    }

    // Course-completion certificates - owner reads own, admins read all
    match /certificates/{certificateId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
          (resource.data.user_id == request.auth.uid || hasAdminPrivileges());
      allow update, delete: if hasAdminPrivileges();
    }

    // Per-user activity log (scans, threat detections, logins) — immutable audit trail
    match /user_activities/{activityId} {
      allow create: if request.auth != null &&
          request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null &&
          resource.data.userId == request.auth.uid;
      allow read: if hasAdminPrivileges();
      allow update, delete: if false;
    }

    // Model-detected scams (from text scans & SMS) — any signed-in user can record;
    // only admins can read/manage for the dashboard.
    match /detected_threats/{detectionId} {
      allow create: if request.auth != null;
      allow read, update, delete: if hasAdminPrivileges();
    }

    // Country emergency / cyber-crime authority contacts — readable by any signed-in
    // user (used by the scan "report to authorities" card + emergency page); admin-managed.
    match /emergency_contacts/{contactId} {
      allow read: if request.auth != null;
      allow write: if hasAdminPrivileges();
    }

    // Admin-only collections
    match /admin/{document=**} {
      allow read, write: if request.auth != null &&
                            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin incident inbox - the app creates an alert here when any user
    // submits a report; only admins can read or manage the inbox.
    match /admin/notifications/incidents/{alertId} {
      allow create: if request.auth != null;
      allow read, update, delete: if hasAdminPrivileges();
    }

    // Aggregate counters incremented client-side on incident submission
    // (transactional read-modify-write, so signed-in users need read too).
    match /admin/dashboard_stats {
      allow read, write: if request.auth != null;
    }
    
    // Main incidents collection (authenticated users can create/read, admins can modify)
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || 
                        isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Cases collection (for case tracking)
    match /cases/{caseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || 
                        isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Global incidents (public reports for admin review)
    match /global_incidents/{incidentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Education content (read-only for authenticated users)
    match /education_content/{contentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    // Education categories (read-only for authenticated users)
    match /education_categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User learning progress (users can read/write their own document)
    match /user_progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Learning sessions (users can create and read their own sessions)
    match /learning_sessions/{sessionId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow update, delete: if false; // immutable records
    }
    
    // Cyber insights (read-only, updated by Cloud Functions)
    match /cyber_insights/{insightId} {
      allow read: if request.auth != null;
      // Only Cloud Functions can write insights
      allow write: if false;
    }
    
    // Role management collections
    match /user_roles/{userId} {
      // Users can read their own role info
      allow read: if request.auth != null && request.auth.uid == userId;
      // Admins (by users-doc role) or permission holders can read all role documents
      allow read: if hasAdminPrivileges() || hasPermission('manage_users') || hasPermission('view_analytics');
      // Admins or users with change_user_roles permission can write
      allow write: if hasAdminPrivileges() || hasPermission('change_user_roles');
    }

    match /role_history/{historyId} {
      // Admins or permission holders can read role history
      allow read: if hasAdminPrivileges() || hasPermission('manage_users') || hasPermission('view_analytics');
      // Admins or users with change_user_roles permission can write role history
      allow write: if hasAdminPrivileges() || hasPermission('change_user_roles');
    }
    
    // Bulk operations audit log (super admin only)
    match /bulk_operations/{operationId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
